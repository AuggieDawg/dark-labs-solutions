DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

OWNER_EMAILS="owner@example.com"
PRIMARY_WORKSPACE_SLUG="dark-labs"
PRIMARY_WORKSPACE_NAME="Dark Labs"

# Vercel Preview migrations are disabled by default. Set this to true only in
# Preview after assigning a database that is separate from Production.
ALLOW_PREVIEW_MIGRATIONS="false"

# Public lead intake and abuse protection.
# Generate both secrets independently with a cryptographically secure password
# generator. CONTACT_FORM_ENABLED defaults to enabled when omitted.
CONTACT_FORM_ENABLED="true"
LEAD_ABUSE_HASH_SECRET="replace-with-an-independent-random-secret-at-least-32-characters"

# Lead notification delivery. LEAD_FROM_EMAIL must use a sender domain verified
# by the configured Resend account. Keep RESEND_API_KEY and CRON_SECRET private.
LEAD_NOTIFICATION_EMAIL="leads@example.com"
LEAD_FROM_EMAIL="leads@example.com"
RESEND_API_KEY="replace-with-resend-api-key"
CRON_SECRET="replace-with-an-independent-random-secret-at-least-32-characters"

# Required locally when Vercel Blob OIDC credentials are not available.
BLOB_READ_WRITE_TOKEN=""

NEXT_PUBLIC_DARK_LABS_CONTACT_EMAIL="contact@example.com"
NEXT_PUBLIC_DARK_LABS_PHONE_DISPLAY="(000) 000-0000"
NEXT_PUBLIC_DARK_LABS_PHONE_HREF="tel:+10000000000"
