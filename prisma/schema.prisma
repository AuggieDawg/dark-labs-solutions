generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  CLIENT
}

enum Visibility {
  OWNER_ONLY
  TEAM_ONLY
  CLIENT_VISIBLE
}

enum ServiceCategory {
  WEBSITES
  AUTOMATIONS
  DASHBOARDS
  PLATFORMS
}

enum ClientStatus {
  LEAD
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ProspectStatus {
  TO_CONTACT
  CONTACTED
  ENGAGED
  QUALIFIED
  NOT_INTERESTED
  DO_NOT_CONTACT
  CONVERTED
  ARCHIVED
}

enum ProspectChannel {
  EMAIL
  PHONE
  LINKEDIN
  FACEBOOK
  IN_PERSON
  REFERRAL
  OTHER
}

enum ClientServiceType {
  WEBSITE
  SEO
  WEB_ANALYTICS
}

enum ClientServiceStatus {
  PLANNED
  ONBOARDING
  ACTIVE
  PAUSED
  COMPLETED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
  SPAM
  ARCHIVED
}

enum LeadTimeline {
  IMMEDIATELY
  ONE_TO_THREE_MONTHS
  THREE_TO_SIX_MONTHS
  EXPLORING
}

enum LeadBudgetRange {
  UNDER_5000
  FROM_5000_TO_10000
  FROM_10000_TO_20000
  FROM_20000_TO_30000
  ABOVE_30000
  NOT_SURE
}

enum LeadNotificationKind {
  OWNER_NEW_LEAD
}

enum LeadNotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum ProjectStatus {
  DISCOVERY
  ACTIVE
  REVIEW
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum DeliverableStatus {
  DRAFT
  IN_PROGRESS
  READY
  DELIVERED
  ARCHIVED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GoalArea {
  BUSINESS
  PERSONAL
  HEALTH
  LEARNING
  FINANCE
  RELATIONSHIPS
  SPIRITUAL
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth.js / NextAuth adapter relations
  accounts Account[]
  sessions Session[]

  // Workspace access
  memberships WorkspaceMembership[]

  // App relations
  createdTasks   Task[]          @relation("TaskCreator")
  assignedTasks  Task[]          @relation("TaskAssignee")
  taskComments   TaskComment[]   @relation("TaskCommentAuthor")
  projectUpdates ProjectUpdate[] @relation("ProjectUpdateAuthor")
  notes          Note[]          @relation("NoteAuthor")
  activityLogs   ActivityLog[]   @relation("ActivityActor")
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id   String @id @default(cuid())
  name String
  slug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       WorkspaceMembership[]
  clients           Client[]
  projects          Project[]
  tasks             Task[]
  taskLinks         TaskLink[]
  goals             Goal[]
  notes             Note[]
  activityLogs      ActivityLog[]
  leads             Lead[]
  leadNotifications LeadNotification[]
  leadRateLimits    LeadRateLimit[]
  prospects         Prospect[]
  clientServices    ClientService[]
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(CLIENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model Client {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  slug        String?
  status      ClientStatus @default(ACTIVE)

  company       String?
  website       String?
  industry      String?
  source        String?
  summary       String?
  internalNotes String?
  logoUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  ClientContact[]
  projects  Project[]
  tasks     Task[]
  notes     Note[]
  leads     Lead[]
  prospects Prospect[]
  services  ClientService[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([workspaceId, name])
}

model Prospect {
  id          String         @id @default(cuid())
  workspaceId String
  clientId    String?
  status      ProspectStatus @default(TO_CONTACT)

  businessName    String
  contactName     String?
  email           String?
  emailNormalized String?
  phone           String?
  websiteUrl      String?
  industry        String?
  location        String?
  source          String?
  valueHypothesis String?

  lastContactChannel ProspectChannel?
  firstContactedAt   DateTime?
  lastContactedAt    DateTime?
  nextFollowUpAt     DateTime?
  convertedAt        DateTime?
  closedAt           DateTime?
  internalNotes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, nextFollowUpAt])
  @@index([workspaceId, businessName])
  @@index([workspaceId, emailNormalized])
  @@index([clientId])
}

model ClientService {
  id          String              @id @default(cuid())
  workspaceId String
  clientId    String
  type        ClientServiceType
  status      ClientServiceStatus @default(PLANNED)

  summary       String?
  primaryUrl    String?
  internalNotes String?
  startedAt     DateTime?
  nextReviewAt  DateTime?
  endedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projects  Project[]

  @@unique([workspaceId, clientId, type])
  @@index([workspaceId, status])
  @@index([workspaceId, type])
  @@index([clientId])
}

model Lead {
  id             String     @id @default(cuid())
  workspaceId    String
  clientId       String?
  reference      String     @unique
  idempotencyKey String
  status         LeadStatus @default(NEW)

  firstName       String
  lastName        String
  email           String
  emailNormalized String
  phone           String?
  businessName    String
  websiteUrl      String?

  engagementSlug     String?
  businessConstraint String
  desiredOutcome     String?
  timeline           LeadTimeline?
  budgetRange        LeadBudgetRange?
  referralSource     String?

  sourcePath  String?
  landingPath String?
  referrerUrl String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?

  privacyAcknowledgedAt DateTime
  privacyNoticeVersion  String

  firstContactedAt DateTime?
  nextFollowUpAt   DateTime?
  convertedAt      DateTime?
  closedAt         DateTime?
  internalNotes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client        Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  notifications LeadNotification[]

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, nextFollowUpAt])
  @@index([workspaceId, emailNormalized])
  @@index([clientId])
}

model LeadNotification {
  id          String                 @id @default(cuid())
  workspaceId String
  leadId      String
  kind        LeadNotificationKind   @default(OWNER_NEW_LEAD)
  status      LeadNotificationStatus @default(PENDING)

  provider          String?
  recipient         String
  providerMessageId String?
  attemptCount      Int       @default(0)
  lastAttemptAt     DateTime?
  nextAttemptAt     DateTime?
  sentAt            DateTime?
  lastError         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, kind])
  @@index([workspaceId, status, nextAttemptAt])
  @@index([leadId])
}

model LeadRateLimit {
  id              String   @id @default(cuid())
  workspaceId     String
  keyHash         String
  windowStartedAt DateTime
  count           Int      @default(1)
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, keyHash, windowStartedAt])
  @@index([expiresAt])
}

model ClientContact {
  id       String @id @default(cuid())
  clientId String

  name      String
  email     String?
  phone     String?
  roleTitle String?
  isPrimary Boolean @default(false)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([email])
}

model Project {
  id              String  @id @default(cuid())
  workspaceId     String
  clientId        String?
  clientServiceId String?

  name       String
  slug       String?
  status     ProjectStatus   @default(DISCOVERY)
  priority   ProjectPriority @default(MEDIUM)
  visibility Visibility      @default(OWNER_ONLY)

  summary              String?
  clientVisibleSummary String?
  internalNotes        String?

  // Public case-study controls. These fields are the only project copy exposed
  // on the Work page; internal and client-visible fields stay private.
  workPageEnabled Boolean   @default(false)
  workTitle       String?
  workClientLabel String?
  workSummary     String?
  workDescription String?
  workChallenge   String?
  workSolution    String?
  workOutcome     String?
  workWebsiteUrl  String?
  workSortOrder   Int       @default(0)
  workPublishedAt DateTime?

  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?

  budgetCents Int?
  currency    String @default("USD")

  showcaseEnabled   Boolean          @default(false)
  showcaseService   ServiceCategory?
  showcaseTitle     String?
  showcaseSummary   String?
  showcaseProblem   String?
  showcaseSolution  String?
  showcaseResults   String?
  showcaseSortOrder Int              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientService ClientService? @relation(fields: [clientServiceId], references: [id], onDelete: SetNull)

  milestones        ProjectMilestone[]
  deliverables      ProjectDeliverable[]
  beforeAfterAssets ProjectBeforeAfterAsset[]
  updates           ProjectUpdate[]
  tasks             Task[]
  notes             Note[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([workspaceId, priority])
  @@index([workPageEnabled, workSortOrder])
  @@index([workspaceId, showcaseEnabled])
  @@index([workspaceId, showcaseService])
  @@index([clientId])
  @@index([clientServiceId])
}

model ProjectMilestone {
  id        String @id @default(cuid())
  projectId String

  title       String
  description String?
  status      MilestoneStatus @default(PLANNED)
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int             @default(0)
  visibility  Visibility      @default(CLIENT_VISIBLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, sortOrder])
}

model ProjectDeliverable {
  id        String @id @default(cuid())
  projectId String

  title       String
  description String?
  url         String?
  status      DeliverableStatus @default(DRAFT)
  visibility  Visibility        @default(OWNER_ONLY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, status])
}

model ProjectUpdate {
  id        String  @id @default(cuid())
  projectId String
  authorId  String?

  title          String?
  body           String
  visibility     Visibility @default(CLIENT_VISIBLE)
  showOnWorkPage Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User?   @relation("ProjectUpdateAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([authorId])
  @@index([projectId, visibility])
  @@index([projectId, showOnWorkPage])
}

model Task {
  id          String  @id @default(cuid())
  workspaceId String
  projectId   String?
  clientId    String?

  parentTaskId String?
  creatorId    String?
  assigneeId   String?

  title       String
  description String?

  status     TaskStatus   @default(TODO)
  priority   TaskPriority @default(MEDIUM)
  visibility Visibility   @default(OWNER_ONLY)

  dueDate     DateTime?
  completedAt DateTime?

  // Workbench map coordinates
  mapX Float @default(40)
  mapY Float @default(40)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  creator  User? @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  assignee User? @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  parentTask Task?  @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks   Task[] @relation("TaskHierarchy")

  comments      TaskComment[]
  outgoingLinks TaskLink[]    @relation("TaskLinkSource")
  incomingLinks TaskLink[]    @relation("TaskLinkTarget")

  @@index([workspaceId, status])
  @@index([workspaceId, priority])
  @@index([workspaceId, dueDate])
  @@index([projectId])
  @@index([clientId])
  @@index([assigneeId])
  @@index([parentTaskId])
}

model TaskLink {
  id           String @id @default(cuid())
  workspaceId  String
  sourceTaskId String
  targetTaskId String

  label String?

  createdAt DateTime @default(now())

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceTask Task      @relation("TaskLinkSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask Task      @relation("TaskLinkTarget", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sourceTaskId, targetTaskId])
  @@index([targetTaskId])
  @@index([workspaceId])
}

model TaskComment {
  id       String  @id @default(cuid())
  taskId   String
  authorId String?

  body       String
  visibility Visibility @default(OWNER_ONLY)

  createdAt DateTime @default(now())

  task   Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User? @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([authorId])
}

model Goal {
  id          String @id @default(cuid())
  workspaceId String

  title           String
  area            GoalArea
  status          GoalStatus   @default(ACTIVE)
  priority        GoalPriority @default(MEDIUM)
  description     String?
  why             String?
  successCriteria String?

  targetDate  DateTime?
  completedAt DateTime?
  progress    Int       @default(0)

  visibility Visibility @default(OWNER_ONLY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  milestones GoalMilestone[]
  notes      Note[]

  @@index([workspaceId, status])
  @@index([workspaceId, area])
  @@index([workspaceId, priority])
}

model GoalMilestone {
  id     String @id @default(cuid())
  goalId String

  title       String
  description String?
  targetDate  DateTime?
  completedAt DateTime?
  progress    Int       @default(0)
  sortOrder   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([goalId, sortOrder])
}

model Note {
  id          String  @id @default(cuid())
  workspaceId String
  clientId    String?
  projectId   String?
  goalId      String?
  authorId    String?

  title      String?
  body       String
  visibility Visibility @default(OWNER_ONLY)
  pinned     Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  goal      Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  author    User?     @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([clientId])
  @@index([projectId])
  @@index([goalId])
  @@index([authorId])
  @@index([workspaceId, visibility])
}

model ProjectBeforeAfterAsset {
  id        String @id @default(cuid())
  projectId String

  label          String?
  beforeImageUrl String?
  afterImageUrl  String?
  notes          String?
  publicEnabled  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ActivityLog {
  id          String  @id @default(cuid())
  workspaceId String
  actorId     String?

  entityType String
  entityId   String
  action     String
  summary    String?
  metadata   Json?

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?     @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([actorId])
  @@index([workspaceId, entityType, entityId])
  @@index([workspaceId, createdAt])
}
